{
  "ReverseProxy": {

    "Routes": {

      "ingestion-route": {
        "ClusterId": "ingestion-cluster",
        "Match": {
          "Path": "/api/ingest/{**catch-all}"
        }
      },


      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },


      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/alarmHub/{**catch-all}"
        }
      }

    },


    "Clusters": {

      "ingestion-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://ingestion:8080/"
          }
        }
      },


      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notification:8080/"
          }
        }
      }

    }
  }
}